HEALTH_TRACKER_URL=https://your-health-tracker-instance.vercel.app
HEALTH_TRACKER_API_KEY=ht_your_api_key_here
MCP_TRANSPORT=stdio
AUTH_MODE=local_api_key
# Optional diagnostic label only; API identity comes from HEALTH_TRACKER_API_KEY.
# LOCAL_INTERNAL_USER_ID=local-api-key-user

# Hosted Auth0 mode
# MCP_TRANSPORT=streamable_http
# AUTH_MODE=oauth_bearer
# MCP_PUBLIC_URL=https://your-health-tracker-mcp.vercel.app
# OAUTH_ISSUER=https://your-tenant.us.auth0.com/
# OAUTH_AUDIENCE=https://mcp.health-tracker.example
# OAUTH_JWKS_URI=https://your-tenant.us.auth0.com/.well-known/jwks.json
# OAUTH_ALLOWED_SUB=google-oauth2|immutable-subject
# HEALTH_TRACKER_INTERNAL_USER_ID=internal-user-id
# HOSTED_PROFILE_ID=optional-fixed-profile-id
# OAUTH_CLOCK_TOLERANCE_SECONDS=60
# AUTH_LOG_HMAC_KEY=generate-at-least-32-random-bytes
